<!DOCTYPE html>
<html lang="en">
<head>
  <% var pageTitle = 'Complaint Details - Smart Complaint Portal'; %>
  <%- include('../partials/head') %>
</head>
<body>
  <div class="admin-layout">
    <%- include('../partials/admin-sidebar') %>

    <div class="admin-content">
      <a href="/admin/complaints" class="btn btn-link mb-3 ps-0"><i class="bi bi-arrow-left me-1"></i>Back to Complaints</a>

      <div class="card border-0 shadow-sm p-4">
        <div class="d-flex justify-content-between align-items-start mb-4">
          <h3 class="fw-bold mb-0"><%= complaint.complaint_id %></h3>
          <% if (complaint.status === 'Pending') { %>
            <span class="badge badge-pending fs-6">Pending</span>
          <% } else if (complaint.status === 'In Progress') { %>
            <span class="badge badge-progress fs-6">In Progress</span>
          <% } else { %>
            <span class="badge badge-resolved fs-6">Resolved</span>
          <% } %>
        </div>

        <div class="row g-4">
          <div class="col-md-7">
            <table class="table table-borderless mb-0">
              <tr><th width="180">Category</th><td><%= complaint.category %></td></tr>
              <tr><th>Description</th><td><%= complaint.description %></td></tr>
              <tr><th>Area Name</th><td><%= complaint.area_name %></td></tr>
              <tr><th>Pin Code</th><td><%= complaint.pincode %></td></tr>
              <tr><th>Assigned Sector</th><td><%= complaint.sector_no %></td></tr>
              <tr><th>Priority</th><td><span class="badge badge-<%= complaint.priority.toLowerCase() %>"><%= complaint.priority %></span></td></tr>
              <tr><th>Date Submitted</th><td><%= new Date(complaint.created_at).toLocaleString() %></td></tr>
            </table>

            <% if (complaint.image_path) { %>
              <div class="mt-3">
                <label class="form-label fw-bold">Uploaded Image</label><br>
                <img src="<%= complaint.image_path %>" class="img-fluid rounded" style="max-height: 280px;" alt="Complaint image">
              </div>
            <% } %>
          </div>

          <div class="col-md-5">
            <label class="form-label fw-bold">Location</label>
            <% if (complaint.latitude && complaint.longitude) { %>
              <div id="detailsMap"></div>
            <% } else { %>
              <div class="alert alert-secondary">No location data available for this complaint.</div>
            <% } %>

            <div class="mt-4">
              <form action="/admin/complaints/<%= complaint.id %>/status" method="POST">
                <label class="form-label fw-bold">Update Status</label>
                <select name="status" class="form-select mb-2">
                  <option value="Pending" <%= complaint.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                  <option value="In Progress" <%= complaint.status === 'In Progress' ? 'selected' : '' %>>In Progress</option>
                  <option value="Resolved" <%= complaint.status === 'Resolved' ? 'selected' : '' %>>Resolved</option>
                </select>
                <button type="submit" class="btn btn-primary w-100">Update Status</button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
  <% if (complaint.latitude && complaint.longitude) { %>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
    <script>
      const map = L.map('detailsMap').setView([<%= complaint.latitude %>, <%= complaint.longitude %>], 14);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap contributors'
      }).addTo(map);
      L.marker([<%= complaint.latitude %>, <%= complaint.longitude %>])
        .addTo(map)
        .bindPopup('<%= complaint.area_name %>')
        .openPopup();
    </script>
  <% } %>
</body>
</html>
