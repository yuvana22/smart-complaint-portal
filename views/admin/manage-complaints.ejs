<!DOCTYPE html>
<html lang="en">
<head>
  <% var pageTitle = 'Manage Complaints - Smart Complaint Portal'; %>
  <%- include('../partials/head') %>
</head>
<body>
  <div class="admin-layout">
    <%- include('../partials/admin-sidebar') %>

    <div class="admin-content">
      <h2 class="fw-bold mb-1">Manage Complaints</h2>
      <p class="text-muted mb-4">View, filter, update, and resolve citizen complaints</p>

      <%- include('../partials/alerts') %>

      <!-- ===================== Filters ===================== -->
      <form action="/admin/complaints" method="GET" class="card border-0 shadow-sm p-3 mb-4">
        <div class="row g-2 align-items-end">
          <div class="col-md-4">
            <label class="form-label small mb-1">Search</label>
            <input type="text" name="search" class="form-control" placeholder="Complaint ID, area, category..." value="<%= filters.search %>">
          </div>
          <div class="col-md-2">
            <label class="form-label small mb-1">Sector</label>
            <select name="sector" class="form-select">
              <option value="">All Sectors</option>
              <% sectors.forEach(function(s) { %>
                <option value="<%= s.sector_no %>" <%= filters.sector === s.sector_no ? 'selected' : '' %>><%= s.sector_no %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-2">
            <label class="form-label small mb-1">Status</label>
            <select name="status" class="form-select">
              <option value="">All Statuses</option>
              <option value="Pending" <%= filters.status === 'Pending' ? 'selected' : '' %>>Pending</option>
              <option value="In Progress" <%= filters.status === 'In Progress' ? 'selected' : '' %>>In Progress</option>
              <option value="Resolved" <%= filters.status === 'Resolved' ? 'selected' : '' %>>Resolved</option>
            </select>
          </div>
          <div class="col-md-2">
            <label class="form-label small mb-1">Sort by Date</label>
            <select name="sort" class="form-select">
              <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Newest First</option>
              <option value="oldest" <%= filters.sort === 'oldest' ? 'selected' : '' %>>Oldest First</option>
            </select>
          </div>
          <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100"><i class="bi bi-funnel-fill me-1"></i>Apply</button>
          </div>
        </div>
      </form>

      <!-- ===================== Complaints Table ===================== -->
      <div class="card border-0 shadow-sm">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Complaint ID</th>
                <th>Category</th>
                <th>Area</th>
                <th>Pin Code</th>
                <th>Sector</th>
                <th>Priority</th>
                <th>Date</th>
                <th>Status</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% if (complaints.length === 0) { %>
                <tr><td colspan="9" class="text-center text-muted py-4">No complaints found matching your filters.</td></tr>
              <% } %>
              <% complaints.forEach(function(c) { %>
                <tr>
                  <td><strong><%= c.complaint_id %></strong></td>
                  <td><%= c.category %></td>
                  <td><%= c.area_name %></td>
                  <td><%= c.pincode %></td>
                  <td><%= c.sector_no %></td>
                  <td><span class="badge badge-<%= c.priority.toLowerCase() %>"><%= c.priority %></span></td>
                  <td><%= new Date(c.created_at).toLocaleDateString() %></td>
                  <td>
                    <form action="/admin/complaints/<%= c.id %>/status" method="POST" class="status-form">
                      <select name="status" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="Pending" <%= c.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                        <option value="In Progress" <%= c.status === 'In Progress' ? 'selected' : '' %>>In Progress</option>
                        <option value="Resolved" <%= c.status === 'Resolved' ? 'selected' : '' %>>Resolved</option>
                      </select>
                    </form>
                  </td>
                  <td>
                    <div class="d-flex gap-1">
                      <a href="/admin/complaints/<%= c.id %>" class="btn btn-sm btn-outline-primary" title="View">
                        <i class="bi bi-eye-fill"></i>
                      </a>
                      <form action="/admin/complaints/<%= c.id %>/delete" method="POST"
                            onsubmit="return confirm('Delete complaint <%= c.complaint_id %>? This cannot be undone.');">
                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                          <i class="bi bi-trash-fill"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
</body>
</html>
