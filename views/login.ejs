<!DOCTYPE html>
<html lang="en">
<head>
  <% var pageTitle = 'Login - Smart Complaint Portal'; %>
  <%- include('partials/head') %>
</head>
<body>
  <div class="auth-wrapper">
    <div class="card auth-card p-4 p-md-5">
      <div class="text-center mb-4">
        <i class="bi bi-box-arrow-in-right" style="font-size:2.5rem; color:#1d4e89;"></i>
        <h3 class="mt-2 fw-bold">User Login</h3>
        <p class="text-muted">Login to manage and track your complaints</p>
      </div>

      <%- include('partials/alerts') %>

      <form action="/login" method="POST">
        <div class="mb-3">
          <label class="form-label">Email Address</label>
          <input type="email" name="email" class="form-control" placeholder="you@example.com" required>
        </div>
        <div class="mb-3">
          <label class="form-label">Password</label>
          <input type="password" name="password" class="form-control" placeholder="Your password" required>
        </div>
        <button type="submit" class="btn btn-primary w-100 py-2">Login</button>
      </form>

      <p class="text-center mt-4 mb-1">
        Don't have an account? <a href="/register">Register here</a>
      </p>
      <p class="text-center mb-0">
        <a href="/admin/login" class="text-muted small"><i class="bi bi-shield-lock me-1"></i>Admin Login</a>
      </p>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
</body>
</html>
