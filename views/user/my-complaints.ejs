<!DOCTYPE html>
<html lang="en">
<head>
  <% var pageTitle = 'My Complaints - Smart Complaint Portal'; %>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/user-navbar') %>

  <div class="container py-5">
    <h2 class="fw-bold mb-1"><i class="bi bi-list-task me-2"></i>My Complaints</h2>
    <p class="text-muted mb-4">All complaints you've submitted</p>

    <%- include('../partials/alerts') %>

    <% if (complaints.length === 0) { %>
      <div class="card border-0 shadow-sm p-5 text-center">
        <i class="bi bi-inbox" style="font-size: 3rem; color: #ccc;"></i>
        <p class="text-muted mt-3 mb-3">You haven't submitted any complaints yet.</p>
        <a href="/complaints/raise" class="btn btn-primary mx-auto" style="width: fit-content;">Raise Your First Complaint</a>
      </div>
    <% } else { %>
      <div class="card border-0 shadow-sm">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Complaint ID</th>
                <th>Category</th>
                <th>Area</th>
                <th>Sector</th>
                <th>Priority</th>
                <th>Date</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% complaints.forEach(function(c) { %>
                <tr>
                  <td><strong><%= c.complaint_id %></strong></td>
                  <td><%= c.category %></td>
                  <td><%= c.area_name %></td>
                  <td><%= c.sector_no %></td>
                  <td>
                    <span class="badge badge-<%= c.priority.toLowerCase() %>"><%= c.priority %></span>
                  </td>
                  <td><%= new Date(c.created_at).toLocaleDateString() %></td>
                  <td>
                    <% if (c.status === 'Pending') { %>
                      <span class="badge badge-pending">Pending</span>
                    <% } else if (c.status === 'In Progress') { %>
                      <span class="badge badge-progress">In Progress</span>
                    <% } else { %>
                      <span class="badge badge-resolved">Resolved</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
</body>
</html>
