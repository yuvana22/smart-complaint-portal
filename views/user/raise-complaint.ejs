<!DOCTYPE html>
<html lang="en">
<head>
  <% var pageTitle = 'Raise Complaint - Smart Complaint Portal'; %>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/user-navbar') %>

  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <h2 class="fw-bold mb-1"><i class="bi bi-file-earmark-plus me-2"></i>Raise a Complaint</h2>
        <p class="text-muted mb-4">Fill in the details below. We'll automatically detect the responsible sector.</p>

        <%- include('../partials/alerts') %>

        <div class="card shadow-sm border-0 p-4">
          <form action="/complaints/raise" method="POST" enctype="multipart/form-data" id="complaintForm">

            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">Category <span class="required-asterisk">*</span></label>
                <select name="category" class="form-select" required>
                  <option value="" disabled selected>Select category</option>
                  <% categories.forEach(function(cat) { %>
                    <option value="<%= cat %>"><%= cat %></option>
                  <% }) %>
                </select>
              </div>

              <div class="col-md-6">
                <label class="form-label">Priority <span class="required-asterisk">*</span></label>
                <select name="priority" class="form-select" required>
                  <option value="" disabled selected>Select priority</option>
                  <option value="Low">Low</option>
                  <option value="Medium">Medium</option>
                  <option value="High">High</option>
                </select>
              </div>

              <div class="col-12">
                <label class="form-label">Description <span class="required-asterisk">*</span></label>
                <textarea name="description" id="description" class="form-control" rows="4" minlength="20"
                  placeholder="Describe the issue in at least 20 characters..." required></textarea>
                <div class="form-text"><span id="charCount">0</span> characters (minimum 20)</div>
              </div>

              <div class="col-md-6">
                <label class="form-label">Area Name <span class="required-asterisk">*</span></label>
                <input type="text" name="area_name" id="area_name" class="form-control" placeholder="e.g. MVP Colony" required>
              </div>

              <div class="col-md-6">
                <label class="form-label">Pin Code <span class="required-asterisk">*</span></label>
                <input type="number" name="pincode" id="pincode" class="form-control" placeholder="e.g. 530017" required>
              </div>

              <div class="col-12">
                <div id="sectorInfo" class="alert alert-info d-none mb-0">
                  <i class="bi bi-diagram-3-fill me-1"></i>
                  Assigned Sector: <strong id="sectorName"></strong>
                </div>
                <div id="sectorNotFound" class="alert alert-warning d-none mb-0">
                  <i class="bi bi-exclamation-triangle-fill me-1"></i>
                  No matching sector found yet. Your complaint will be marked "Unassigned" until matched.
                </div>
              </div>

              <div class="col-12">
                <div id="previewMap" style="height: 220px; border-radius: 10px; display:none;"></div>
              </div>

              <div class="col-12">
                <label class="form-label">Upload Image <span class="text-muted">(optional)</span></label>
                <input type="file" name="image" class="form-control" accept="image/*">
              </div>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2 mt-4">
              <i class="bi bi-send-fill me-1"></i>Submit Complaint
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
  <script>
    // ---------- Character counter for description ----------
    const descField = document.getElementById('description');
    const charCount = document.getElementById('charCount');
    descField.addEventListener('input', () => {
      charCount.textContent = descField.value.trim().length;
    });

    // ---------- Live sector auto-detection (AJAX) ----------
    const areaInput = document.getElementById('area_name');
    const pincodeInput = document.getElementById('pincode');
    const sectorInfo = document.getElementById('sectorInfo');
    const sectorNameEl = document.getElementById('sectorName');
    const sectorNotFound = document.getElementById('sectorNotFound');
    const previewMapDiv = document.getElementById('previewMap');

    let previewMap = null;
    let previewMarker = null;
    let debounceTimer = null;

    function detectSector() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(async () => {
        const area = areaInput.value.trim();
        const pin = pincodeInput.value.trim();
        if (!area && !pin) {
          sectorInfo.classList.add('d-none');
          sectorNotFound.classList.add('d-none');
          previewMapDiv.style.display = 'none';
          return;
        }
        try {
          const res = await fetch(`/complaints/detect-sector?area_name=${encodeURIComponent(area)}&pincode=${encodeURIComponent(pin)}`);
          const data = await res.json();

          if (data.found) {
            sectorNameEl.textContent = data.sector_no;
            sectorInfo.classList.remove('d-none');
            sectorNotFound.classList.add('d-none');

            // Show map preview using fixed lat/lng from area_sector table
            previewMapDiv.style.display = 'block';
            const lat = parseFloat(data.latitude);
            const lng = parseFloat(data.longitude);

            if (!previewMap) {
              previewMap = L.map('previewMap').setView([lat, lng], 14);
              L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap contributors'
              }).addTo(previewMap);
              previewMarker = L.marker([lat, lng]).addTo(previewMap);
            } else {
              previewMap.setView([lat, lng], 14);
              previewMarker.setLatLng([lat, lng]);
            }
            setTimeout(() => previewMap.invalidateSize(), 200);
          } else {
            sectorInfo.classList.add('d-none');
            sectorNotFound.classList.remove('d-none');
            previewMapDiv.style.display = 'none';
          }
        } catch (err) {
          console.error('Sector detection failed:', err);
        }
      }, 500); // debounce 500ms
    }

    areaInput.addEventListener('input', detectSector);
    pincodeInput.addEventListener('input', detectSector);
  </script>
</body>
</html>
