# ===========================================
# Smart Complaint Management Portal - ENV
# ===========================================
# Copy this file to ".env" and fill in your actual values
# Command: cp .env.example .env

# Server Port
PORT=3000

# MySQL Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=complaint_portal
DB_PORT=3306

# Session Secret (use any long random string)
SESSION_SECRET=csp_super_secret_key_change_this_in_production

# Default Admin Credentials (also seeded in SQL, kept here for reference)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
